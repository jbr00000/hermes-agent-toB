# Hermes to-B Agent — environment variables.
# Copy to $HERMES_HOME/.env and fill in. SECRETS ONLY (behavioral config -> config.yaml).
# HERMES_HOME itself is set in the environment (it's the directory holding this .env).

# =============================================================================
# LLM PROVIDER — pick the one matching config.yaml `model`.
# =============================================================================

# DeepSeek (https://platform.deepseek.com/) — default dev provider
DEEPSEEK_API_KEY=

# Z.AI / Zhipu GLM (https://z.ai) — model e.g. glm-4.6 / glm-4-plus
# GLM_API_KEY=

# Alibaba Bailian / Qwen (https://dashscope.aliyun.com) — model e.g. qwen-plus / qwen-max
# DASHSCOPE_API_KEY=

# Self-hosted OpenAI-compatible endpoint: use the `custom` provider in config.yaml
# (model: <your-model>), and set whichever API-key env var your endpoint reads.

# =============================================================================
# DATABASE — the customer's business DB, read-only (db_query tool).
# Read-only MUST be enforced at the DB GRANT layer (the connecting user is
# SELECT-only); the tool + the sandbox share these credentials.
# =============================================================================
# SQLite (dev):        sqlite:///path/to/business.db
# Postgres/MySQL/etc.: install SQLAlchemy + the driver, then a SQLAlchemy URL.
HERMES_DB_URL=

# =============================================================================
# SANDBOX — terminal/execute_code run here. Docker-only by default (decision 5).
# =============================================================================
TERMINAL_ENV=docker
# CN-mirror image; swap to python:3.12-slim etc. where Docker Hub is reachable.
TERMINAL_DOCKER_IMAGE=docker.m.daocloud.io/library/python:3.12-slim

# =============================================================================
# HEADLESS SERVER
# =============================================================================
HERMES_SERVER_HOST=0.0.0.0     # 0.0.0.0 inside a container (so -p reaches uvicorn)
HERMES_SERVER_PORT=8000
# First-run admin bootstrap. If unset, defaults admin/changeme (+ a loud warning).
# HERMES_ADMIN_USERNAME=admin
# HERMES_ADMIN_PASSWORD=

# =============================================================================
# FEATURE FLAGS — elevated capabilities, default OFF (decision 5).
# The frontend reads GET /features and exposes these as opt-in buttons.
# =============================================================================
# HERMES_FEATURE_COMPUTER_USE=false   # desktop control (needs cua-driver)
# HERMES_FEATURE_HOST_TERMINAL=false  # agent may run shell on the HOST (false = sandbox only)
