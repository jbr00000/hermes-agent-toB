# Hermes to-B Agent — configuration.
# Copy to $HERMES_HOME/config.yaml. BEHAVIORAL settings only (secrets in .env).
# Trimmed to the keys this fork actually uses; everything else uses defaults
# from hermes_cli/config.py:DEFAULT_CONFIG.

# === MODEL ============================================================
# Provider is auto-detected from the model name (deepseek-* -> deepseek, etc.)
# or chosen via `hermes model`. Kept providers: deepseek, zai (GLM),
# alibaba (Bailian/Qwen), custom (self-hosted OpenAI-compatible).
model: deepseek-v4-pro

agent:
  # "none" disables thinking (parse_reasoning_effort -> {"enabled": False}).
  # Valid: none, minimal, low, medium, high, xhigh. Disable for DeepSeek-V4
  # to avoid the reasoning_content echo trap.
  reasoning_effort: "none"
  max_turns: 90            # tool-calling iterations per conversation

# === FEATURE FLAGS ====================================================
# Elevated capabilities default OFF (decision 5: no host access by default).
# The frontend toggles via GET/POST /features. Env: HERMES_FEATURE_<UPPER>.
features:
  host_terminal: false     # true = agent may run shell on the HOST server
                           # false (default) = Docker sandbox ONLY

# === TERMINAL / SANDBOX ==============================================
# terminal/execute_code run inside the Docker sandbox. Image is taken from
# TERMINAL_DOCKER_IMAGE env; set here as a fallback default.
# terminal:
#   docker_image: docker.m.daocloud.io/library/python:3.12-slim

# === MEMORY ===========================================================
# Local SQLite (memory.db in HERMES_HOME) — decision 7. All cloud memory
# providers were removed (data stays in the customer env).

# === SESSIONS =========================================================
# SQLite state.db in HERMES_HOME, with FTS5 cross-session search.
# Defaults are fine; see docs/session-lifecycle.md for the model.

# === SECURITY =========================================================
# Tool approval, command allowlists, audit — see docs/security/.
# Defaults enforce the sandbox + per-user isolation boundaries.
